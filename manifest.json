{
  "manifest_version": 3,
  "name": "Recipe Porter",
  "version": "1.0",
  "description": "Transfer recipes from Cookidoo to Monsieur Cuisine.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://cookidoo.cz/*",
        "*://www.monsieur-cuisine.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}